{
    "name": "Fine Print",
    "description": "Scans Terms and Conditions and flags concerns, rights given up, and positives.",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
      "default_icon": "icons/t&c_apply.png"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],
    "permissions": [
      "sidePanel",
      "scripting",
      "activeTab",
      "tabs"
    ],
    "host_permissions": [
      "http://127.0.0.1:5000/*",
      "http://localhost:5000/*"
    ],
    "side_panel": {
      "default_path": "sidepanel/sidepanel.html"
    },
    "web_accessible_resources": [
      { 
        "resources": ["pdfjslib/build/pdf.mjs", "pdfjslib/build/pdf.worker.mjs"],
        "matches": ["<all_urls>"]
      }
  ]
  }