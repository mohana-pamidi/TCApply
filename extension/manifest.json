{
    "name": "T&C Apply",
    "description": "Scans Terms and Conditions and flags privacy risks",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
      "default_icon": "icons/t&c_apply.png"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],
    "permissions": [
      "sidePanel"
    ],
    "side_panel": {
      "default_path": "sidepanel/sidepanel.html"
    }
  }